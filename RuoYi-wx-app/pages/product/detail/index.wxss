.detail-page {
  padding-bottom: 220rpx;
}

.detail-hero {
  min-height: 300rpx;
  color: #ffffff;
}

.detail-hero__tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.detail-hero__title {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.detail-hero__desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.detail-price-row__origin {
  color: #94a3b8;
  font-size: 22rpx;
}

.detail-sales {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}

.chip-row,
.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.spec-item {
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
}

.detail-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.detail-bar__btn {
  flex: 1;
  border-radius: 18rpx;
}
