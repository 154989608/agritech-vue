<view class="page">
  <view class="card">
    <view class="section-title"><text class="section-title__main">订单列表</text><text class="section-title__sub">交易状态</text></view>
    <view class="filter-row"><view class="filter-pill {{activeFilter === item ? 'is-active' : ''}}" wx:for="{{filters}}" wx:key="*this" bindtap="switchFilter" data-filter="{{item}}">{{item}}</view></view>
  </view>
  <view class="card" wx:for="{{orderList}}" wx:key="sn">
    <view class="order-head"><text class="order-head__sn">订单号 {{item.sn}}</text><text class="chip chip--warm">{{item.statusText}}</text></view>
    <view class="order-goods">
      <view class="order-goods__item" wx:for="{{item.items}}" wx:key="id">
        <view class="order-goods__cover" style="background: {{item.bg}};"></view>
        <view class="order-goods__body"><text class="order-goods__title">{{item.title}}</text><text class="order-goods__desc">{{item.desc}}</text></view>
      </view>
    </view>
    <view class="order-foot"><text class="muted">共 {{item.count}} 件</text><text class="price">¥{{item.total}}</text></view>
  </view>
</view>
