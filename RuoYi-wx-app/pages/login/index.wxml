<view class="page login-page">
  <view class="card login-card">
    <text class="login-title">账号登录</text>
    <text class="login-desc">输入任意账号密码即可进入演示状态。</text>
    <view class="form-field"><text class="form-field__label">账号</text><input class="input form-field__input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" /></view>
    <view class="form-field"><text class="form-field__label">密码</text><input class="input form-field__input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" /></view>
    <button class="btn-primary login-card__btn" bindtap="handleLogin">立即登录</button>
  </view>
</view>
