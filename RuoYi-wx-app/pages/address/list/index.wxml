<view class="page">
  <view class="card">
    <view class="section-title"><text class="section-title__main">地址管理</text><text class="section-title__sub" bindtap="addAddress">新增地址</text></view>
    <view class="address-list">
      <view class="address-item" wx:for="{{addressList}}" wx:key="id">
        <view class="address-item__head"><text class="address-item__name">{{item.name}}</text><text wx:if="{{item.isDefault}}" class="chip chip--warm">默认</text></view>
        <text class="address-item__phone">{{item.phone}}</text><text class="address-item__detail">{{item.detail}}</text>
      </view>
    </view>
  </view>
</view>
