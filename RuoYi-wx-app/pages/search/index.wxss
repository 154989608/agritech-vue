.search-page__bar {
  margin-bottom: 24rpx;
}

.search-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-result {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
}

.search-result + .search-result {
  border-top: 1px solid #eef2f7;
}

.search-result__cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  flex: none;
}

.search-result__body {
  flex: 1;
}

.search-result__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.search-result__desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.search-result__foot {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-top: 14rpx;
}

.search-result__meta {
  color: #94a3b8;
  font-size: 22rpx;
}
