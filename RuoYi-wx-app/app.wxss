page {
  background: #f3f8eb;
  color: #1f2937;
  font-size: 28rpx;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(163, 230, 53, 0.14), transparent 32%),
    radial-gradient(circle at top right, rgba(34, 197, 94, 0.1), transparent 28%),
    linear-gradient(180deg, #f4fbef 0%, #f3f8eb 26%, #f3f8eb 100%);
}

.page--tab {
  padding-bottom: 176rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 38rpx rgba(38, 60, 22, 0.08);
  box-sizing: border-box;
}

.card--soft {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 248, 235, 0.98));
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.section-title__main {
  font-size: 34rpx;
  font-weight: 700;
}

.section-title__sub {
  color: #6b7280;
  font-size: 24rpx;
}

.subtle,
.muted {
  color: #6b7280;
}

.btn-primary {
  background: linear-gradient(135deg, #ff7a45 0%, #ff922b 100%);
  color: #ffffff;
}

.btn-secondary {
  background: #eaf7dc;
  color: #3f7a2f;
}

.pill,
.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #eaf7dc;
  color: #4f7c39;
}

.chip--warm {
  background: #fff7ed;
  color: #c2410c;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(56, 94, 35, 0.08);
}

.search-bar__text {
  margin-left: 12rpx;
  color: #64748b;
  font-size: 26rpx;
}

.input {
  width: 100%;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
}

.grid-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.grid-2 > view {
  width: calc(50% - 10rpx);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  color: #e23d28;
  font-weight: 700;
}

.price__small {
  font-size: 22rpx;
  font-weight: 500;
}

.empty {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #64748b;
}
