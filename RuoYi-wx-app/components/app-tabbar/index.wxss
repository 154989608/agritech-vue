.tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
  display: flex;
  padding: 14rpx 10rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 50rpx rgba(35, 55, 22, 0.16);
  backdrop-filter: blur(20rpx);
}

.tabbar__item {
  flex: 1;
  text-align: center;
  color: #6b7280;
}

.tabbar__item.is-active {
  color: #4f7c39;
}

.tabbar__icon {
  display: block;
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 6rpx;
  border-radius: 16rpx;
  background: #f3f8eb;
  line-height: 48rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.tabbar__item.is-active .tabbar__icon {
  background: linear-gradient(135deg, #8bc34a 0%, #4caf50 100%);
  color: #ffffff;
}

.tabbar__text {
  display: block;
  font-size: 22rpx;
}
